  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "MOMENTO\nQuesto deriva da una nozione fisica molto importante.\nIl momento
    di una forza \xE8 il prodotto di una forza per la distanza dall\u2019incastro
    alla quale viene applicata.\nQuesto prodotto da\u2019 un valore, che indica quanto
    in un determinato punto la forza sta cercando di ruotare la struttura. L\u2019appoggio
    o il vincolo in questo caso ostacola il movimento, fino a che resiste.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
